{
  "projectName": "cardgames",
  "version": "3.1",
  "backend": {
    "phases": {
      "build": {
        "commands": []
      }
    },
    "artifacts": {
      "files": []
    }
  },
  "frontend": {
    "phases": {
      "preBuild": {
        "commands": [
          "npm install -g pnpm",
          "pnpm install --frozen-lockfile"
        ]
      },
      "build": {
        "commands": [
          "pnpm run build"
        ]
      }
    },
    "artifacts": {
      "baseDirectory": "dist",
      "files": [
        "**/*"
      ]
    },
    "cache": {
      "paths": [
        "node_modules/**/*",
        ".pnpm-store/**/*"
      ]
    }
  }
}

